{
  "name": "gdluxx",
  "sideEffects": false,
  "private": true,
  "version": "0.10.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:gdluxx/gdluxx.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --config ./svelte.config.js",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --config ./svelte.config.js --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fix-all": "pnpm format; pnpm lint:fix",
    "validate-themes": "node scripts/validate-themes.js",
    "test:themes": "vitest run tests/theme-system.test.js",
    "theme-check": "pnpm validate-themes && pnpm test:themes"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "ansi_up": "^6.0.6",
    "conventional-commits-parser": "6.4.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "release-it": "^20.2.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.22",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.43.3",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@lezer/highlight": "^1.2.3",
    "@sveltejs/adapter-node": "^5.5.7",
    "better-auth": "^1.6.22",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.11",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  }
}
